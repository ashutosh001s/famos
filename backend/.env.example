# FamOS Environment Configuration Template
# Copy this file to .env and fill in real values
# Run setup.sh to generate keys automatically
#
# NEVER commit .env to git — it is in .gitignore

# Flask session signing key (generate: python3 -c "import secrets; print(secrets.token_urlsafe(40))")
SECRET_KEY=replace-with-40-random-chars

# JWT token signing key (generate separately from SECRET_KEY)
JWT_SECRET_KEY=replace-with-different-40-random-chars

# Database — SQLite (default) or PostgreSQL
DATABASE_URI=sqlite:///app.db
# DATABASE_URI=postgresql://user:pass@localhost/famos_db

# AES-256 encryption key for password vault
# Generate: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# WARNING: Back this up offline. Losing it = vault data permanently unreadable.
VAULT_ENCRYPTION_KEY=replace-with-fernet-key-ending-in-equals-sign=

# GitHub webhook secret — set the same value in GitHub repo Settings → Webhooks
# Generate: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
GITHUB_WEBHOOK_SECRET=replace-with-random-secret
